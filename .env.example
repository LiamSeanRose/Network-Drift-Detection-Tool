# .env.example — copy to .env and fill in. docker-compose reads these at
# `docker compose up`. The real .env is gitignored; never commit tokens.
#
#   cp .env.example .env

# --- NetBox (source of truth) ---------------------------------------------
# The scheduler reads intent from NetBox. Inside a container, the host is
# reachable as host.docker.internal (NOT localhost).
NETBOX_URL=http://host.docker.internal:8000
NETBOX_TOKEN=

# --- Auto-remediation (v2.5 / v3.0) ---------------------------------------
# Global kill-switch. Must be "true" before ANY auto-apply can run. The
# per-issue auto_apply_enabled flag and the per-device pause
# (PATCH /devices/{name}/auto-apply) still apply on top of this.
AUTO_REMEDIATION_ENABLED=false

# --- Webhooks (v3.0) ------------------------------------------------------
# Outbound notification endpoint (Slack/PagerDuty/etc.). Leave empty to
# disable webhooks entirely — no dispatch, no error.
WEBHOOK_URL=

# Comma-separated event types to dispatch.
# Valid values: critical_drift, apply_success, apply_failure.
WEBHOOK_EVENTS=critical_drift,apply_success,apply_failure

# Allow webhook URLs that point at private/loopback addresses (e.g. an on-prem
# Slack or a sidecar receiver). Default false rejects them as an SSRF guard.
WEBHOOK_ALLOW_PRIVATE=false
